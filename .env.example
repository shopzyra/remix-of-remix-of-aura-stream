# ===== APP =====
VITE_APP_NAME=Auralis
VITE_APP_DESCRIPTION=Modern premium music streaming
VITE_APP_URL=http://localhost:5173

# ===== BRANDING (oklch or hex) =====
VITE_LOGO_TEXT=Auralis
VITE_ENABLE_GLASSMORPHISM=true
VITE_ENABLE_ANIMATIONS=true

# ===== SEO =====
VITE_META_TITLE=Auralis — Premium music streaming
VITE_META_DESCRIPTION=Modern, fast, beautiful music streaming
VITE_META_KEYWORDS=music,streaming,audio,playlists

# ===== SUPABASE (auto-populated from Lovable Cloud / Supabase project) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ===== AUTH PROVIDERS =====
VITE_AUTH_EMAIL=true
VITE_AUTH_GOOGLE=true
VITE_AUTH_GITHUB=false
VITE_AUTH_MICROSOFT=false

# ===== DONATIONS =====
VITE_DONATION_PROVIDER=paypal           # paypal | kofi | ''
VITE_DONATION_LINK=https://paypal.me/yourname
VITE_DONATION_LABEL=Support Auralis

# ===== AUDIO =====
VITE_ENABLE_HIFI=true
VITE_ENABLE_CROSSFADE=true
VITE_CROSSFADE_SECONDS=4
VITE_ENABLE_VISUALIZER=true
VITE_ENABLE_DEVICE_SWITCHING=true

# ===== FEATURES =====
VITE_ENABLE_LYRICS=true
VITE_ENABLE_SOCIAL=true
VITE_ENABLE_DOWNLOADS=true
VITE_ENABLE_UPLOADS=true

# ===== CATALOG =====
VITE_AUDIUS_APP_NAME=auralis            # Audius requires app_name in requests

# ===== LEGAL =====
VITE_COMPANY_NAME=Auralis Labs
VITE_COMPANY_EMAIL=hello@auralis.app
VITE_SUPPORT_EMAIL=support@auralis.app

# ===== ANALYTICS =====
VITE_ENABLE_ANALYTICS=false
